<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.library.HelloController">

    <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

    <!-- Верхняя панель -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Библиотека" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

        <Label text="Источник данных:" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="sourceBox" prefWidth="170"/>
        <Button text="Загрузить" onAction="#onLoad" style="-fx-base: #2196F3; -fx-text-fill: white;"/>
    </HBox>

    <!-- Кнопки действий -->
    <HBox spacing="10">
        <Button text="Добавить книгу" onAction="#onAdd"
                style="-fx-base: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
        <Button text="Изменить статус" onAction="#onToggleStatus"
                style="-fx-font-size: 14px;"/>
        <Button text="Удалить выбранную" onAction="#onDelete"
                style="-fx-base: #f44336; -fx-text-fill: white; -fx-font-size: 14px;"/>
        <Button text="Синхронизировать" onAction="#onSync"/>
    </HBox>

    <!-- Форма добавления (всегда видимая, без TitledPane) -->
    <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-background-color: #f8f9fa; -fx-padding: 12; -fx-border-color: #ddd; -fx-border-radius: 4;">
        <Label text="Название:"/>
        <TextField fx:id="fieldTitle" prefWidth="260" promptText="Название книги"/>

        <Label text="Автор:"/>
        <TextField fx:id="fieldAuthor" prefWidth="190" promptText="Автор"/>

        <Label text="Год:"/>
        <TextField fx:id="fieldYear" prefWidth="85" promptText="Год"/>
    </HBox>

    <!-- Таблица книг -->
    <Label text="Список книг" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <TableView fx:id="bookTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"     text="ID"      prefWidth="55"/>
            <TableColumn fx:id="colTitle"  text="Название" prefWidth="320"/>
            <TableColumn fx:id="colAuthor" text="Автор"   prefWidth="220"/>
            <TableColumn fx:id="colYear"   text="Год"     prefWidth="75"/>
            <TableColumn fx:id="colStatus" text="Статус"  prefWidth="140"/>
        </columns>
    </TableView>

    <!-- Лог операций (всегда видимый) -->
    <Label text="Лог операций" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
    <TextArea fx:id="logArea" editable="false" prefHeight="140"
              style="-fx-font-family: monospace; -fx-font-size: 13;"/>

</VBox>